# ── Slack ────────────────────────────────────────────────
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=4a0cde5d7110e67e71d578ac05d0e339
DEVOPS_CHANNEL_ID=C0B8W28B0UC            # channel the bot listens in
SLACK_HISTORY_CHANNEL_ID=C0B8XXXXXX     # channel to ingest history from (can be different)

# ── LLM ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-key-here            # console.groq.com → API Keys (free)
ANTHROPIC_API_KEY=sk-ant-your-key-here    # optional: switch back to Claude
OPENAI_API_KEY=sk-your-key-here           # optional: only needed for OpenAI embeddings

# ── Vector store ─────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Confluence ───────────────────────────────────────────
CONFLUENCE_URL=https://yourcompany.atlassian.net
CONFLUENCE_USERNAME=you@yourcompany.com
CONFLUENCE_API_TOKEN=your-confluence-token
CONFLUENCE_SPACE_KEY=DEVOPS               # space to index

# ── Jira ─────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=you@yourcompany.com
JIRA_API_TOKEN=your-jira-token
JIRA_PROJECT_KEY=INFRA                    # project to index

# ── Bitbucket ────────────────────────────────────────────
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_ACCESS_TOKEN=your-access-token  # bitbucket.org → workspace Settings → Security → Access tokens (Repositories: Read)
BITBUCKET_PROJECT=NIN2                    # project key to scope repo discovery (leave blank for all)
BITBUCKET_REPOS=                          # comma-separated slugs; if set, overrides PROJECT filter

# ── Ingestion ────────────────────────────────────────────
INGEST_SCHEDULE_HOURS=6                   # re-index every 6 hours
